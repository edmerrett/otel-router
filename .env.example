# Copy this file to `.env` and fill in real values. `.env` is gitignored so
# your secrets never reach version control. Load it with:
#
#   docker run --env-file .env ...
#
# Only INBOUND_TOKEN is required by the router itself. Every other variable here
# exists only because the SHIPPED example destinations.yaml references it. When
# you edit destinations.yaml to add, remove, or rename destinations, you decide
# which variables exist and what they are called; keep this file in sync.
#
# Generate INBOUND_TOKEN with real randomness, never by hand:
#   openssl rand -hex 32
#
# All destination endpoints MUST be https:// in production. Auth headers and
# telemetry travel in the request and are readable over plain HTTP.

# --- required: the token every sender must present as "Authorization: Bearer <token>"
INBOUND_TOKEN=replace-with-output-of-openssl-rand-hex-32

# --- example destination A (otlphttp/backend): native OTLP backend, all signals
BACKEND_ENDPOINT=https://your-backend.example.com:4318
BACKEND_AUTH=Bearer replace-with-backend-token

# --- example destination B (otlphttp/webhook): webhook-style feed, logs only
WEBHOOK_ENDPOINT=https://REGION-provider.example.com/.../feeds/FEED_ID:import
WEBHOOK_API_KEY=replace-with-provider-api-key
WEBHOOK_SECRET=replace-with-feed-secret-key

# --- optional: refuse to start unless these outbound variables are all set.
# The router only enforces INBOUND_TOKEN by default; list the destination
# variables you cannot run without to get the same fail-closed guarantee.
#REQUIRE_ENV=BACKEND_ENDPOINT BACKEND_AUTH WEBHOOK_ENDPOINT WEBHOOK_API_KEY WEBHOOK_SECRET

# --- optional: serve TLS on the OTLP ports (4317/4318) instead of plaintext.
# Off by default: the usual deployment terminates TLS in front (ALB, reverse
# proxy). Enable when clients connect directly or your load balancer uses an
# HTTPS target group (ALB does not validate target certs, so a self-signed
# cert is fine there). Paths are *container* paths, so mount the PEM files in:
#
#   docker run --env-file .env -v $(pwd)/certs:/certs:ro ...
#
# Self-signed cert for testing (set SAN to the hostname clients dial):
#   openssl req -x509 -newkey rsa:2048 -nodes -days 365 \
#     -keyout certs/tls.key -out certs/tls.crt \
#     -subj "/CN=otel-router" -addext "subjectAltName=DNS:otel-router"
#
#TLS_ENABLED=true
#TLS_CERT_FILE=/certs/tls.crt
#TLS_KEY_FILE=/certs/tls.key
