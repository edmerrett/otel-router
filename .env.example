# Copy this file to `.env` and fill in real values. `.env` is gitignored so
# your secrets never reach version control. Load it with:
#
#   docker run --env-file .env ...
#
# Generate INBOUND_TOKEN with real randomness, never by hand:
#   openssl rand -hex 32
#
# All destination endpoints MUST be https:// in production — the auth headers
# and telemetry travel in the request and are readable over plain HTTP.

# --- inbound: the token every sender must present as "Authorization: Bearer <token>"
INBOUND_TOKEN=replace-with-output-of-openssl-rand-hex-32

# --- destination A: webhook-style SIEM feed (e.g. Google SecOps), logs only
SIEM_ENDPOINT=https://REGION-chronicle.googleapis.com/.../feeds/FEED_ID:importPushLogs
SIEM_API_KEY=replace-with-google-cloud-api-key
SIEM_SECRET=replace-with-feed-secret-key

# --- destination B: native OTLP backend (e.g. Harmonic Security), all signals
APP_ENDPOINT=https://your-backend.example.com:4318
APP_AUTH=Bearer replace-with-backend-token
